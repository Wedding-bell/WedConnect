# --- PRODUCTION ENVIRONMENT VARIABLES ---
# Copy this to .env.prod on your EC2 instance

DEBUG=False
SECRET_KEY=change-me-to-a-very-long-random-string
ALLOWED_HOSTS=your-ec2-public-ip,your-domain.com

# RDS Database Configuration
POSTGRES_DB=wedconnect_db
POSTGRES_USER=your_rds_username
POSTGRES_PASSWORD=your_rds_password
POSTGRES_HOST=your-rds-endpoint.xxxx.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432

# Redis & Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email (Example for AWS SES or Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
