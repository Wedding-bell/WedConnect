# =========================================
# WedConnect Project .gitignore
# =========================================

# ----------------------
# Python / Django
# ----------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.env
*.venv
env/
venv/
ENV/

# Django database and logs
*.sqlite3
*.log
media/
staticfiles/
static/

# Django migrations (optional: usually safe to track, but ignored here)
**/migrations/__pycache__/
**/migrations/*.pyc

# ----------------------
# Testing / Coverage
# ----------------------
.pytest_cache/
.coverage
htmlcov/
nosetests.xml
coverage.xml
*.cover

# ----------------------
# IDEs / Editors
# ----------------------
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
*.swp
.DS_Store
Thumbs.db

# ----------------------
# Docker
# ----------------------
*.dockerignore
docker-compose.override.yml
docker-compose.*.yml
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Ignore Postgres / Redis data directories if mounted locally
postgres_data/
redis_data/

# ----------------------
# Frontend (Svelte/React/Vue)
# ----------------------
node_modules/
dist/
build/
npm-debug.log*
yarn-error.log*
.vite/
.env.local
.env.development.local
.env.test.local
.env.production.local

# ----------------------
# Misc
# ----------------------
*.log
*.bak
*.tmp